if (
    "{{ module_type }}" in config
    and "{{ module_name }}" in config["{{ module_type }}"]
    and "{{ etl_name }}" in config["{{ module_type }}"]["{{ module_name }}"]
):
    validate(
        config,
        WORKFLOW_BASE / "schemas/{{ module_type }}/{{ module_name }}/{{ etl_name }}/config.schema.yaml",
    )

rule {{ module_type }}_{{ module_name }}_{{ etl_name }}_all:
    """
    This rule will run the entire {{ etl_name }} workflow
    to generate {{ etl_description }}.

    input
    -----
    readme:
        A README file that describes the data and the workflow.

    params
    ------
    func:
        The function in the {{ package_name }} package to call in
        order to execute this rule.

    log
    ---
    loguru:
        The log file where python will log to using loguru.

    conda
    -----
    The {{ package_name }} conda environment
    with the `runner` extra dependencies.

    script
    ------
    The standard script for running rules in the {{ package_name }} package.
    Reads `params.func` to determine which function to call.
    """
    input:
        # TODO: Define input files if needed. All inputs should be named.
        readme="data/README.md",
    # output:
        # `_all` rules do not produce any output files directly,
        # instead the `input` in this rule requests the output
        # from other rules.
    # wildcards:
    # TODO: Add wildcards if needed. All wildcards should be named.
    params:
        func=(
            "{{ package_name }}.{{ module_type }}.{{ module_name }}"
            ".{{ etl_name }}.runner.main:run_smk"
        ),
    log:
        loguru=str(
            LOG_DIR
            / "{{ module_type }}_{{ module_name }}_{{ etl_name }}_all"
            / "loguru.log"
        ),
        # TODO add `stdout` and/or `stderr` if the python calls
        #   a subprocess that produces output.
    conda:
        config["CONDA"]["ENVS"]["RUNNER"]
    script:
        str(WORKFLOW_BASE / "scripts" / "rules_conda_RUNNER" / "{{ package_name }}_rules.py")
