def load(df: DataFrame[Schema], path: pathlib.Path | str) -> None:
    """
    Persist *df* to disk as a Parquet file.

    Parameters
    ----------
    df
        Transformed DataFrame validated by :class:`Schema`.
    path
        File path where the Parquet file will be written.
    """
    path = pathlib.Path(path)
    path.parent.mkdir(parents=True, exist_ok=True)
    df.to_parquet(path, index=False)
