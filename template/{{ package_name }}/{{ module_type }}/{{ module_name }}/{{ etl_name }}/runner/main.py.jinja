def run(smk: Snakemake) -> None:
    """
    {{ etl_description }}

    Parameters
    ----------
    smk: Snakemake
        The Snakemake object containing the workflow context, including input,
        output, parameters, wildcards, resources, and log files.
        Passed via the snakemake `script:` directive.

    Raises
    ------
    ValueError
        If the input or output arguments are not valid paths or dictionaries with the required keys.
    AssertionError
        If the input or output pandera validation failed.
    """

    # --- Parse Snakemake arguments ---------------------------------------------
    artifact_path = smk.input.get("artifact_path")
    if not isinstance(artifact_path, (str, Path)):
        # This check ensures the type is either a string or a Path object;
        # helping to keep the type checker happy from here forward.
        raise TypeError(
            "Expected smk.input.artifact_path to be a string or Path, "
            "got: {}".format(type(artifact_path))
        )
    artifact_path = Path(artifact_path)

    tickers_raw = smk.params.get("tickers")
    if not isinstance(tickers_raw, list):
        raise TypeError(
            "Expected smk.params.tickers to be a list of ticker symbols, "
            "got: {}".format(type(tickers_raw))
        )
    tickers = tickers_raw

    # --- Configure logging --------------------------------------------------------
    log_path = smk.log.get("loguru")
    if not isinstance(log_path, (str, Path)):
        raise TypeError(
            "Expected smk.log.loguru to be a string or Path, "
            "got: {}".format(type(log_path))
        )
    log_path = Path(log_path)
    configure_file_logger(log_path, context=smk.wildcards)

    # --- Extract from external API ------------------------------------------------
    logger.info(f"Fetching quotes for {', '.join(tickers)} …")
    df_external = extract_external.extract_external(tickers)
    logger.info("✅ Raw data validated with SchemaExternal")

    # --- Transform ----------------------------------------------------------------
    df_transformed = transform.transform(df_external)
    logger.info("✅ Transformed data validated with Schema")

    # --- Load ---------------------------------------------------------------------
    load.load(df_transformed, artifact_path)
    logger.info(f"📁 Written to {artifact_path.resolve()}")

    # --- Extract (from disk) ------------------------------------------------------
    df_read_back = extract.extract(artifact_path)
    logger.info("✅ Read-back data validated with Schema")

    # Show the final result
    logger.info(df_read_back.to_string(index=False))

@app.command()
def main(
    tickers: Annotated[
        List[str],
        typer.Argument(help=textwrap.dedent(
            """
            List of ticker symbols to fetch quotes for
            (e.g., AAPL, MSFT, GOOGL, AMZN).
            """
        ).strip()),
    ],
    artifact_path: Annotated[
        Path,
        typer.Argument(help=textwrap.dedent(
            """
            Path to save the output Parquet file
            (e.g.,: data/average_price.parquet).
            """
        ).strip()),
    ],
    log_path: Annotated[
        Path,
        typer.Argument(help=textwrap.dedent(
            """
            Path to save the log file
            (e.g.,: logs/runner.log).
            """
        ).strip()),
    ],
    rulename: Annotated[
        str,
        typer.Argument(help=textwrap.dedent(
            """
            Name of the Snakemake rule to run this ETL process.
            This is used to identify the rule in the Snakemake workflow.
            Default is "run_{{ etl_name }}".
            """
        ).strip()),
    ],
) -> None:
    """
    Main entry point for the {{ etl_name_long }} ETL process.

    Default values are not specified here to avoid confusing
    results when accidentally falling back to defaults.
    """

    # Create a Snakemake object with all required fields
    # just as a snakemake rule would provide.
    smk = Snakemake(
        input_=InputFiles(fromdict={
            "artifact_path": str(artifact_path),
        }),
        output=OutputFiles(fromdict={}),
        params=Params(fromdict={
            "tickers": tickers,
        }),
        wildcards=Wildcards(),
        threads=1,
        resources=Resources(),
        log=Log(fromdict={
            "loguru": str(log_path),
        }),
        config={},
        rulename=rulename,
        bench_iteration=None,
    )

    # Run the ETL process
    run(smk)

if __name__ == "__main__":
    app()
