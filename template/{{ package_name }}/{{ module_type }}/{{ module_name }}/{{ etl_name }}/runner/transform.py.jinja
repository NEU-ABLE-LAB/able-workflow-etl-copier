def transform(
    df_external: DataFrame[SchemaExternal],
) -> DataFrame[Schema]:
    """
    Compute the average market price across all tickers.

    Parameters
    ----------
    df_external
        The raw quote data validated by :class:`SchemaExternal`.

    Returns
    -------
    DataFrame[Schema]
        A single-row DataFrame with the average price and timestamp.
    """
    avg_price = df_external["regularMarketPrice"].mean()
    # Convert the *latest* market time (epoch seconds) to UTC datetime
    latest_ts = datetime.fromtimestamp(
        int(df_external["regularMarketTime"].max()), tz=timezone.utc
    )
    out = pd.DataFrame(
        {
            "average_price": [avg_price],
            "as_of": [latest_ts],
        }
    )
    return pa.typing.DataFrame[Schema](out)
